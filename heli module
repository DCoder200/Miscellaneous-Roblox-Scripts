-- function to turn 
function heliActions.turn(vehiclePart, lookVector)
	local context = setContext(vehiclePart)
	task.wait()
	
	-- compare look vector to vehicle look vector 
	local vehicleLookVector = vehiclePart.CFrame.LookVector
	local dot = vehicleLookVector:Dot(lookVector) -- how close vectors are (1 means equal and < 1 isn't)
	local cross = vehicleLookVector:Cross(lookVector) -- indicates which side makes up the difference with - or +

	-- check difference (dot product)
	if dot < 0.8 then
		
		-- turn vehicle cframe left
		if cross.Y < 0 then -- only need Y value because we only want to turn left or right
			print("turn left")
			vehiclePart.CFrame = vehiclePart.CFrame * CFrame.Angles(0, -0.05, 0)
			
		else -- turn cframe right
			print("turn right")
			vehiclePart.CFrame = vehiclePart.CFrame * CFrame.Angles(0, 0.05, 0)
		end
	end
end

