-- shared by client and server so both apply the same transforms to their respective models

-- services
local RunService = game:GetService("RunService")

-- store some vehicle data
local vehicleData = {}

-- function to determine if script is being used by client or server
local function setContext(vehiclePart)
	if not vehiclePart then return "server" end
	if vehiclePart then return "client" end
end

local heliActions = {}

-- function to startup rotor logic
function heliActions.startup(vehiclePart)
	local context = setContext(vehiclePart)
	
	-- make sure vehicleData[vehiclePart] exists
	vehicleData[vehiclePart] = {
		lastDirection = Vector3.zero,
	}
	
	-- super simplified logic
	--RunService.Heartbeat:Connect(function()
	--	local up = vehiclePart.CFrame.UpVector
	--	local direction = Vector3.new(up.X, 0, up.Z)

	--	vehiclePart.CFrame += direction
	--end)
	
	local rotorPower = 50

	RunService.Heartbeat:Connect(function(deltaTime)
		
		-- CFrame components to get "up" and "forward" directions
		local cf = vehiclePart.CFrame
		local up = cf.UpVector  -- "up" direction of the CFrame (changes from any applied rotations)
		local forward = cf.LookVector -- "forward" direction of the CFrame 

		-- horizontal movement based on tilt (UpVector), takes into account roll and yaw
		local horizontal = Vector3.new(up.X, 0, up.Z) -- ignore Y
		if horizontal.Magnitude > 0 then
			horizontal = horizontal.Unit * (1 - up.Y)  -- scale by tilt
		end

		-- scale forward movement based on pitch 
		local pitchAmount = -forward.Y  -- forward tilt
		local forwardBoost = Vector3.new(forward.X, (forward.Y * 0.1), forward.Z) * pitchAmount -- small bit of descension if look vector pitched down

		-- final movement direction
		local direction = horizontal + forwardBoost
		
		-- cache last direction if there's none
		if vehicleData[vehiclePart].lastDirection == Vector3.zero then
			vehicleData[vehiclePart].lastDirection = direction

		else -- lerp from last direction to direction
			direction = vehicleData[vehiclePart].lastDirection:Lerp(direction, 0.1)
			vehicleData[vehiclePart].lastDirection = direction
		end

		-- apply movement
		vehiclePart.CFrame += ((direction * rotorPower) * deltaTime)
	end)
end

-- function to increase altitude
function heliActions.increaseAltitude(vehiclePart)
	local context = setContext(vehiclePart)
	task.wait()
	
	-- move vehicle cframe up 
	vehiclePart.CFrame = vehiclePart.CFrame * CFrame.new(0, 0.25, 0)
end

-- function to decrease altitude
function heliActions.decreaseAltitude(vehiclePart)
	local context = setContext(vehiclePart)
	task.wait()
	
	-- move vehicle cframe down
	vehiclePart.CFrame = vehiclePart.CFrame * CFrame.new(0, -0.25, 0)
end

