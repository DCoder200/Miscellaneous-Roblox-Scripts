-- local script in starter player scripts
-- services
local UserInputService = game:GetService("UserInputService") -- declare service variable

-- player variables
local player = game.Players.LocalPlayer -- use this for player, might be tempted to use passed player from remote but it's unreliable
local character = player.Character or player.CharacterAdded:Wait()
local humanoid = character:WaitForChild("Humanoid")
local root = character:WaitForChild("HumanoidRootPart")

-- detect respawns and reset variables
player.CharacterAdded:Connect(function(character)
	character = character
	humanoid = character:WaitForChild("Humanoid")
	root = character:WaitForChild("HumanoidRootPart")
end)

